<IfModule mod_rewrite.c>
    <IfModule mod_negotiation.c>
        Options -MultiViews -Indexes
    </IfModule>

    RewriteEngine On

    # Handle Authorization Header
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # Handle X-XSRF-Token Header
    RewriteCond %{HTTP:x-xsrf-token} .
    RewriteRule .* - [E=HTTP_X_XSRF_TOKEN:%{HTTP:X-XSRF-Token}]

    # Redirect Trailing Slashes If Not A Folder...
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} (.+)/$
    RewriteRule ^ %1 [L,R=301]

    # 🔒 STEP 1: Block download managers by User-Agent
    RewriteCond %{HTTP_USER_AGENT} "(IDM|FDM|JDownloader|GetRight|FlashGet|DAP|Download Master|Mass Downloader|NetTransport|ReGet|Star Downloader|Free Download Manager|Internet Download Manager|DownThemAll|Go!Zilla|FreshDownload|LeechGet|NetAnts|AntDownload|Downloader)" [NC]
    RewriteRule ^(.*)$ /nice-try.html [R=302,L]

    # 🔒 STEP 2: Block direct access to video files from external sites
    RewriteCond %{HTTP_REFERER} !^https?://(www\.)?djsmith\.co\.ke [NC]
    RewriteCond %{REQUEST_URI} \.(mp4|mkv|avi|mov|wmv|flv|webm|m3u8|ts)$ [NC]
    RewriteRule ^(.*)$ /nice-try.html [R=302,L]

    # Send Requests To Front Controller...
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^ index.php [L]
</IfModule>

# 🔒 SECURITY HEADERS
<IfModule mod_headers.c>
    # Prevent MIME-type sniffing
    Header set X-Content-Type-Options "nosniff"

    # Prevent clickjacking
    Header always append X-Frame-Options "SAMEORIGIN"

    # Force inline playback for video files
    <FilesMatch "\.(mp4|mkv|avi|mov|wmv|flv|webm)$">
        Header set Cache-Control "no-cache, no-store, must-revalidate"
        Header set Pragma "no-cache"
        Header set Expires 0
        Header set X-Content-Type-Options "nosniff"
        Header set Content-Disposition "inline"
    </FilesMatch>
</IfModule>
